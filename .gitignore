# ─── Database ─────────────────────────────────────────────────────────────────
# Ignore the entire db directory (contains schema SQL & local Wrangler D1 data)
db/

# SQL dump / migration files that may contain sensitive data
*.sql

# ─── Environment & Secrets ────────────────────────────────────────────────────
.env
.env.*
!.env.example
!.env.test

# Wrangler local dev secrets (never commit)
.dev.vars
.dev.vars.*
!.dev.vars.example

# ─── Dependencies ─────────────────────────────────────────────────────────────
node_modules/

# ─── Build Outputs ────────────────────────────────────────────────────────────
.output/
.vercel/
.netlify/
.wrangler/
/.svelte-kit/
/build/
/dist/

# ─── Cloudflare / Wrangler ────────────────────────────────────────────────────
worker-configuration.d.ts

# ─── OS & Editor ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
.vscode/settings.json

# ─── Logs ─────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
